{
  "name": "small-teacher",
  "version": "1.0.0",
  "description": "CLI recreation of the Texas Instruments Little Professor toy",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "serve": "ts-node src/server.ts",
    "serve:prod": "npm run build && node dist/server.js"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
